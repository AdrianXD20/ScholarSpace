# URL base del backend (sin barra final). Ej: https://api.tudominio.com
VITE_API_URL=http://localhost:3000

# Para producción, cambia a: VITE_API_URL=https://portafolio-personal-uy4r.onrender.com

# Opcional: fuerza autenticación mock aunque exista URL (solo pruebas)
# VITE_USE_MOCK_AUTH=true

# Cuando tengas API: define VITE_API_URL y, si no quieres mock, desactiva explícitamente:
# VITE_USE_MOCK_AUTH=false
